# === 應用程式 ===
APP_ENV=development
APP_PORT=8180
APP_SECRET_KEY=change-this-to-a-random-secret-key
JWT_EXPIRE_MINUTES=480
OTP_EXPIRE_MINUTES=10
OTP_MAX_RETRIES=5

# === Global DB (台灣 PostgreSQL) ===
GLOBAL_DB_HOST=your-postgres-host
GLOBAL_DB_PORT=5432
GLOBAL_DB_NAME=ctbc_global
GLOBAL_DB_USER=your-username
GLOBAL_DB_PASSWORD=your-password

# === Local DB 連線 (JSON 格式) ===
# PostgreSQL 必填，MongoDB 選填（聊天功能需要）
LOCAL_DB_CONFIG={"TW":{"pg_host":"your-postgres-host","pg_port":5432,"pg_db":"ctbc_local_tw","pg_user":"your-username","pg_password":"your-password","mongo_uri":"mongodb://your-mongo-host:27017","mongo_db":"ctbc_local_tw"}}

# === CORS ===
CORS_ORIGINS=["http://localhost:5173","http://localhost:8079"]

# === Email (選填，開發環境 OTP 會 log 到 console) ===
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
