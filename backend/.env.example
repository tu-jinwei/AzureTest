# === 應用程式 ===
APP_ENV=development
APP_PORT=8180
APP_SECRET_KEY=change-this-to-a-random-secret-key
JWT_EXPIRE_MINUTES=480
OTP_EXPIRE_MINUTES=10
OTP_MAX_RETRIES=5

# === Global DB (台灣 PostgreSQL) ===
GLOBAL_DB_HOST=your-postgres-host
GLOBAL_DB_PORT=5432
GLOBAL_DB_NAME=ctbc_global
GLOBAL_DB_USER=your-username
GLOBAL_DB_PASSWORD=your-password

# === Local DB 連線 (JSON 格式) ===
# PostgreSQL 必填，MongoDB 選填（聊天功能需要）
LOCAL_DB_CONFIG={"TW":{"pg_host":"your-postgres-host","pg_port":5432,"pg_db":"ctbc_local_tw","pg_user":"your-username","pg_password":"your-password","mongo_uri":"mongodb://your-mongo-host:27017","mongo_db":"ctbc_local_tw"}}

# === Portal MongoDB（對話歷史專用，獨立 DB） ===
PORTAL_MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
PORTAL_MONGO_DB=ctbc_portal

# === CORS ===
CORS_ORIGINS=["http://localhost:5173","http://localhost:8079"]

# === Agatha Public API ===
AGATHA_API_URL=https://uat.heph-ai.net/agatha/public/api/public-api-keys/chat
AGATHA_API_KEY=your-agatha-api-key
AGATHA_API_TIMEOUT=120

# === Email (選填，開發環境 OTP 會 log 到 console) ===
# 正式環境必須設定，否則 OTP 無法寄送
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=noreply@your-domain.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=CTBC AI Portal <noreply@your-domain.com>

# === PII Detection & Redaction ===
PII_ENABLED=false
PII_CONFIDENCE_THRESHOLD=0.5
PII_CHAT_AUTO_REDACT=true
PII_REDACT_MODE=replace
PII_BLOCK_UPLOAD=true
PII_BLOCK_CHAT=true
PII_LANGUAGES=en,zh
# 排除不需要偵測的 entity type（逗號分隔）
# 常見可排除：DATE_TIME, LOCATION, URL, NRP（國籍/宗教/政治）
PII_EXCLUDED_ENTITIES=DATE_TIME,LOCATION,URL,NRP
